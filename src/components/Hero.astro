---
const enquiryTypes = [
  'Exhibition Stand',
  'Product Display',
  'Networking Event',
  'Outdoor Event',
  'Pop-up Display',
  'Retail Fit-out',
  'Vinyl Print Cutting',
  'Other',
];

const locations = ['Sydney', 'Melbourne', 'Brisbane', 'Gold Coast', 'Other'];
---

<section class="relative min-h-screen flex items-center bg-brand-dark overflow-hidden">
  <!-- Background pattern -->
  <div class="absolute inset-0">
    <div class="absolute inset-0 bg-brand-dark"></div>
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;0.5&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    <div class="absolute top-20 left-10 w-96 h-96 bg-brand-gold/10 rounded-full blur-3xl opacity-70"></div>
    <div class="absolute bottom-20 right-10 w-80 h-80 bg-brand-gold/10 rounded-full blur-3xl opacity-50"></div>
  </div>

  <div class="relative content-box pt-28 pb-16 lg:pt-32 lg:pb-20">
    <div class="grid lg:grid-cols-5 gap-10 lg:gap-14 items-center">
      <!-- Content -->
      <div class="lg:col-span-3 space-y-8">
        <div class="hero-entrance hero-entrance-delay-1 inline-flex items-center gap-2 px-4 py-2 rounded-full bg-brand-gold/10 border border-brand-gold/20">
          <span class="w-2 h-2 rounded-full bg-brand-gold animate-pulse"></span>
          <span class="text-brand-gold text-xs font-medium tracking-wide uppercase">Custom Exhibition Stands</span>
        </div>

        <h1 class="hero-entrance hero-entrance-delay-2 font-display text-4xl sm:text-5xl lg:text-[3.5rem] font-extrabold text-white leading-[1.1] tracking-tight">
          Custom Exhibition Stands That
          <span class="text-brand-gold"> Demand Attention</span>
        </h1>

        <p class="hero-entrance hero-entrance-delay-3 text-lg sm:text-xl text-gray-300 leading-relaxed max-w-xl">
          We design, build, and deliver standout exhibition stands from our local factories in
          <span class="text-white font-medium">Sydney</span>,
          <span class="text-white font-medium">Melbourne</span>, and
          <span class="text-white font-medium">Brisbane</span> — helping your brand shine at every event.
        </p>

        <div class="hero-entrance hero-entrance-delay-4 flex flex-col sm:flex-row gap-4">
          <a href="#contact" class="btn-primary !py-4 !px-8 text-base">
            Let's Build Your Stand
            <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
          <a href="#about" class="btn-outline !py-4 !px-8 text-base">
            Learn More
          </a>
        </div>

        <!-- Stats -->
        <div class="hero-entrance hero-entrance-delay-5 flex flex-wrap gap-x-10 gap-y-4 pt-4">
          <div>
            <span class="font-display text-3xl font-bold text-white">2+</span>
            <p class="text-xs text-gray-400 mt-1">Years Experience</p>
          </div>
          <div>
            <span class="font-display text-3xl font-bold text-white">50+</span>
            <p class="text-xs text-gray-400 mt-1">Projects Delivered</p>
          </div>
          <div>
            <span class="font-display text-3xl font-bold text-white">1</span>
            <p class="text-xs text-gray-400 mt-1">Workshop Location</p>
          </div>
        </div>
      </div>

      <!-- Quote Form -->
      <div class="lg:col-span-2 hero-entrance hero-entrance-delay-6">
        <div class="bg-white rounded-2xl p-6 sm:p-8 shadow-xl shadow-black/10 hover-lift hover:shadow-2xl hover:shadow-black/15">
          <h2 class="font-display text-2xl font-bold text-gray-900 mb-1">Request a Quote</h2>
          <p class="text-sm text-gray-500 mb-6">Get a free design consultation</p>

          <form class="space-y-4" id="hero-form">
            <input
              type="text"
              name="name"
              placeholder="Name"
              required
              class="w-full px-4 py-3 rounded-lg border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-brand-gold/50 focus:border-brand-gold transition-all placeholder:text-gray-400"
            />
            <input
              type="email"
              name="email"
              placeholder="Email*"
              required
              class="w-full px-4 py-3 rounded-lg border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-brand-gold/50 focus:border-brand-gold transition-all placeholder:text-gray-400"
            />
            <input
              type="tel"
              name="phone"
              placeholder="Phone*"
              required
              class="w-full px-4 py-3 rounded-lg border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-brand-gold/50 focus:border-brand-gold transition-all placeholder:text-gray-400"
            />
            <select
              name="enquiry_type"
              required
              class="w-full px-4 py-3 rounded-lg border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-brand-gold/50 focus:border-brand-gold transition-all text-gray-400"
            >
              <option value="" disabled selected>Enquiry Type</option>
              {enquiryTypes.map((type) => (
                <option value={type} class="text-gray-900">{type}</option>
              ))}
            </select>
            <select
              name="location"
              required
              class="w-full px-4 py-3 rounded-lg border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-brand-gold/50 focus:border-brand-gold transition-all text-gray-400"
            >
              <option value="" disabled selected>Select Location</option>
              {locations.map((loc) => (
                <option value={loc} class="text-gray-900">{loc}</option>
              ))}
            </select>
            <textarea
              name="message"
              placeholder="Message"
              rows="3"
              class="w-full px-4 py-3 rounded-lg border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-brand-gold/50 focus:border-brand-gold transition-all placeholder:text-gray-400 resize-none"
            ></textarea>
            <button type="submit" class="btn-primary w-full !py-3.5 text-base">
              Submit
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 hidden lg:flex flex-col items-center gap-2">
    <span class="text-gray-500 text-xs tracking-wider uppercase">Scroll</span>
    <div class="w-5 h-8 rounded-full border-2 border-gray-600 flex items-start justify-center p-1">
      <div class="w-1 h-2 rounded-full bg-brand-gold animate-bounce"></div>
    </div>
  </div>
</section>
