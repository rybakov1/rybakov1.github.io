---
const testimonials = [
  {
    name: 'Melissa Henderson',
    role: 'Boutique Owner, Sydney',
    text: 'Brij & Co exceeded all my expectations! They helped design and create the perfect exterior sign for my boutique. The team paid attention to every detail and even suggested improvements I hadn\'t considered. The result is stunning!',
    rating: 5,
  },
  {
    name: 'James O\'Connor',
    role: 'Marketing Manager, Melbourne',
    text: 'We worked with Brij & Co on a custom exhibition stand, and it was a fantastic experience! From concept to execution, everything was done with our needs in mind. Excellent quality and reasonable prices.',
    rating: 5,
  },
  {
    name: 'Sophie Laurent',
    role: 'Graphic Designer, Sydney',
    text: 'I reached out to Brij & Co for a custom sign for one of my clients. The entire process, from the initial consultation to delivery, was seamless. The team is incredibly professional, and the sign looks amazing!',
    rating: 5,
  },
  {
    name: 'Tayane Saga Lago',
    role: 'Beauty Keeps Transforming',
    text: 'We had such a great experience working with Brij & Co for our stand at the Sydney Hair Festival. The booth was beautifully executed, and the quality and attention to detail really stood out. Everyone loved it!',
    rating: 5,
  },
  {
    name: 'Heidi Anne',
    role: 'Tilley Soaps',
    text: 'Brij & Co. have built our Gift Fair stands for several years now and always do a fantastic job. Professional, reliable, and great attention to detail. We highly recommend them.',
    rating: 5,
  },
  {
    name: 'Leticia Prado',
    role: 'Beauty Keeps Transforming',
    text: 'Brij & Co could bring my vision to life. Organising those type of events can be stressful but they made the experience very pleasant and easy. I will definitely be using their services again.',
    rating: 5,
  },
];
---

<section class="section-padding bg-brand-cream">
  <div class="content-box">
    <div class="text-center mb-12 animate-on-scroll">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-brand-gold/10 mb-4">
        <span class="text-brand-brown text-xs font-semibold tracking-wide uppercase">Testimonials</span>
      </div>
      <h2 class="section-title text-gray-900 mb-4">What Our Clients Say</h2>
      <p class="text-brand-brown font-medium text-sm">Customer Satisfaction Is Our #1 Priority</p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {testimonials.map((t, i) => (
        <div
          class="animate-on-scroll hover-lift group bg-white rounded-2xl p-6 md:p-8 border border-gray-200 hover:border-brand-gold/20 hover:shadow-xl hover:shadow-black/5"
          data-delay={String((i % 6) + 1)}
        >
          <!-- Stars -->
          <div class="flex gap-0.5 mb-4">
            {Array.from({ length: t.rating }).map(() => (
              <svg class="w-4 h-4 text-brand-gold" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            ))}
          </div>

          <!-- Quote -->
          <p class="text-gray-600 text-sm leading-relaxed mb-6 line-clamp-5">
            "{t.text}"
          </p>

          <!-- Author -->
          <div class="flex items-center gap-3 pt-4 border-t border-gray-100">
            <div class="w-10 h-10 rounded-full bg-brand-gold/10 flex items-center justify-center">
              <span class="font-display font-bold text-brand-gold text-sm">{t.name.charAt(0)}</span>
            </div>
            <div>
              <h4 class="font-semibold text-gray-900 text-sm">{t.name}</h4>
              <p class="text-xs text-gray-500">{t.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
