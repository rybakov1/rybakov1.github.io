---

---

<section id="about" class="section-padding bg-white">
  <div class="content-box">
    <div class="grid lg:grid-cols-2 gap-10 lg:gap-14 items-center">
      <!-- Image -->
      <div class="animate-on-scroll">
        <div class="relative">
          <div class="aspect-[4/3] rounded-2xl overflow-hidden bg-brand-dark">
            <img
              src="/good_images_pack/CES1.jpg"
              alt="Brij & Co exhibition stand — custom display design and build"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
          <div class="absolute -bottom-6 -right-6 w-32 h-32 bg-brand-gold/10 rounded-2xl -z-10"></div>
          <div class="absolute -top-4 -left-4 w-24 h-24 border-2 border-gray-400/30 rounded-2xl -z-10"></div>
        </div>
      </div>

      <!-- Content -->
      <div class="animate-on-scroll">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-brand-gold/10 mb-6">
          <span class="text-brand-gold text-xs font-semibold tracking-wide uppercase">About Us</span>
        </div>

        <h2 class="section-title text-gray-900 mb-6">
          Premium & Custom Exhibition Stand Builders
        </h2>

        <div class="space-y-4 text-gray-600 leading-relaxed">
          <p>
            Brij & Co. is a top end-to-end custom exhibition display solutions provider in Australia. We transform your ideas into appealing solutions to enhance your presence in any trade show.
          </p>
          <p>
            The company provides all the solutions you may need for participating in a trade show in Australia under one roof. We take care of everything from designing to installing so that you can focus on your core business.
          </p>
          <p>
            As custom exhibition stand builders based in Sydney, Brij & Co ensures your brand leaves a lasting impression on the show floor — for events across NSW and Australia.
          </p>
        </div>

        <div class="grid grid-cols-2 gap-6 mt-8">
          <div class="flex items-start gap-3">
            <div class="w-10 h-10 rounded-lg bg-brand-gold/10 flex items-center justify-center shrink-0 mt-0.5">
              <svg class="w-5 h-5 text-brand-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            </div>
            <div>
              <h4 class="font-semibold text-gray-900 text-sm">Quality Assured</h4>
              <p class="text-xs text-gray-500 mt-1">Premium materials & expert craftsmanship</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <div class="w-10 h-10 rounded-lg bg-brand-gold/10 flex items-center justify-center shrink-0 mt-0.5">
              <svg class="w-5 h-5 text-brand-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <div>
              <h4 class="font-semibold text-gray-900 text-sm">On-Time Delivery</h4>
              <p class="text-xs text-gray-500 mt-1">Always ready before your event</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <div class="w-10 h-10 rounded-lg bg-brand-gold/10 flex items-center justify-center shrink-0 mt-0.5">
              <svg class="w-5 h-5 text-brand-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <div>
              <h4 class="font-semibold text-gray-900 text-sm">Sydney Workshop</h4>
              <p class="text-xs text-gray-500 mt-1">Ingleburn, NSW — we deliver Australia-wide</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <div class="w-10 h-10 rounded-lg bg-brand-gold/10 flex items-center justify-center shrink-0 mt-0.5">
              <svg class="w-5 h-5 text-brand-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            </div>
            <div>
              <h4 class="font-semibold text-gray-900 text-sm">End-to-End</h4>
              <p class="text-xs text-gray-500 mt-1">Design, build, install & dismantle</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
