---
const services = [
  { label: 'Exhibition Stands', href: '#services' },
  { label: 'Product Display Stands & Props', href: '#services' },
  { label: 'Networking Events', href: '#services' },
  { label: 'Outdoor Events', href: '#services' },
  { label: 'Pop-up Displays & Retail Fit-outs', href: '#services' },
  { label: 'Event & Exhibition Furniture Hire', href: '#services' },
  { label: 'Vinyl Print Cutting Sydney', href: '#services' },
];

const locations = ['Sydney', 'Melbourne', 'Brisbane, QLD'];
---

<footer class="bg-brand-dark border-t border-white/5">
  <div class="content-box section-padding !pb-10">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8">
      <!-- Brand -->
      <div>
        <a href="/" class="flex items-center gap-3 mb-6">
          <img src="/logo.png" alt="Brij & Co" class="h-10 w-auto brightness-0 invert" width="120" height="40" />
          <span class="font-display font-bold text-white text-lg">Brij & Co</span>
        </a>
        <p class="text-gray-400 text-sm leading-relaxed mb-6">
          Contact us today to learn about how we can bring your design and construction dreams to life.
        </p>
        <div class="flex gap-3">
          <a href="https://www.facebook.com/brijnco.com.au/" target="_blank" rel="noopener" class="w-9 h-9 rounded-full bg-white/5 hover:bg-brand-gold/20 text-gray-400 hover:text-brand-gold flex items-center justify-center transition-all duration-300" aria-label="Facebook">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
          </a>
          <a href="https://www.instagram.com/brijnco/" target="_blank" rel="noopener" class="w-9 h-9 rounded-full bg-white/5 hover:bg-brand-gold/20 text-gray-400 hover:text-brand-gold flex items-center justify-center transition-all duration-300" aria-label="Instagram">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
          </a>
        </div>
      </div>

      <!-- Services -->
      <div>
        <h4 class="font-display font-semibold text-white mb-6 text-sm uppercase tracking-wider">Our Services</h4>
        <ul class="space-y-3">
          {services.map((s) => (
            <li>
              <a href={s.href} class="text-gray-400 hover:text-brand-gold text-sm transition-colors duration-200 flex items-center gap-2">
                <svg class="w-3 h-3 text-brand-gold shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/></svg>
                {s.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-display font-semibold text-white mb-6 text-sm uppercase tracking-wider">Contact Details</h4>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-brand-gold mt-1 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <span class="text-gray-400 text-sm">4/8 Kerr Road Ingleburn NSW, 2565</span>
          </li>
          {locations.map((loc) => (
            <li class="flex items-center gap-3">
              <svg class="w-4 h-4 text-brand-gold shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/></svg>
              <span class="text-gray-400 text-sm">{loc}</span>
            </li>
          ))}
          <li class="flex items-center gap-3">
            <svg class="w-4 h-4 text-brand-gold shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            <a href="tel:1800957469" class="text-gray-400 hover:text-brand-gold text-sm transition-colors">1800 957 469</a>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-4 h-4 text-brand-gold shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            <a href="mailto:info@brijnco.com" class="text-gray-400 hover:text-brand-gold text-sm transition-colors">info@brijnco.com</a>
          </li>
        </ul>
      </div>

      <!-- Working Hours -->
      <div>
        <h4 class="font-display font-semibold text-white mb-6 text-sm uppercase tracking-wider">Working Hours</h4>
        <ul class="space-y-3 text-sm text-gray-400">
          <li class="flex justify-between"><span>Mon - Fri</span><span class="text-gray-300">8:00 AM - 5:00 PM</span></li>
          <li class="flex justify-between"><span>Saturday</span><span class="text-gray-300">By Appointment</span></li>
          <li class="flex justify-between"><span>Sunday</span><span class="text-gray-500">Closed</span></li>
        </ul>
        <div class="mt-8">
          <a href="/contact" class="btn-primary w-full text-center !text-xs">REQUEST A QUOTE</a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-gray-500 text-xs">&copy; 2026 Brij & Co. All rights reserved.</p>
      <div class="flex gap-6 text-xs text-gray-500">
        <a href="#" class="hover:text-gray-300 transition-colors">Privacy Policy</a>
        <a href="#" class="hover:text-gray-300 transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
