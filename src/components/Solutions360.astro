---

<section class="section-padding bg-brand-cream">
  <div class="content-box">
    <div class="text-center mb-12 animate-on-scroll">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-brand-gold/10 mb-4">
        <span class="text-brand-brown text-xs font-semibold tracking-wide uppercase">Complete Solutions</span>
      </div>
      <h2 class="section-title text-gray-900 mb-4">
        360° Trade Show & Exhibition Strategies
      </h2>
      <p class="section-subtitle text-gray-600">
        Custom solutions for exhibitions and trade shows in Australia, from beginning to end. We make trade show participation a success story worth sharing.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {strategies.map((item, i) => (
        <div
          class="animate-on-scroll hover-lift bg-white rounded-xl p-6 border border-gray-200 hover:border-brand-gold/20 hover:shadow-lg hover:shadow-black/5"
          data-delay={String((i % 6) + 1)}
        >
          <div class="flex items-center gap-4 mb-4">
            <div class="w-11 h-11 rounded-lg bg-brand-gold/10 flex items-center justify-center text-brand-gold shrink-0">
              <Fragment set:html={item.icon} />
            </div>
            <h3 class="font-display font-bold text-gray-900">{item.title}</h3>
          </div>
          <p class="text-gray-500 text-sm leading-relaxed">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
