---
const benefits = [
  'Simplifies complex planning through start-to-finish support.',
  'Builds stronger connections with potential clients and industry partners.',
  'We aid you in closing your deals successfully with the clients.',
  'Whether you attend a local B2B showcase or a grand industry expo, our 360° solutions give you the best business outcomes.',
];

const features = [
  {
    title: 'Experience',
    value: '2+',
    unit: 'Years',
    description: 'Hands-on experience and a focus on quality — we deliver exhibition stands that stand out.',
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>`,
  },
  {
    title: 'Support',
    value: '100',
    unit: '%',
    description: 'We support you from planning to project completion, ensuring your success and satisfaction.',
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>`,
  },
  {
    title: 'Timeliness',
    value: '99',
    unit: '%',
    description: 'Your project will be completed on time, even with tight deadlines, as we ensure quick results.',
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  },
  {
    title: 'Quality',
    value: '5.0',
    unit: '★',
    description: 'We use trusted materials and advanced technologies for top product quality.',
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z"/></svg>`,
  },
];
---

<section class="section-padding bg-brand-dark relative overflow-hidden">
  <div class="absolute inset-0">
    <div class="absolute top-0 right-0 w-96 h-96 bg-brand-gold/10 rounded-full blur-3xl opacity-60"></div>
    <div class="absolute bottom-0 left-0 w-80 h-80 bg-brand-gold/10 rounded-full blur-3xl opacity-40"></div>
  </div>

  <div class="content-box relative">
    <div class="text-center mb-12 animate-on-scroll">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-brand-gold/10 border border-brand-gold/20 mb-4">
        <span class="text-brand-gold text-xs font-semibold tracking-wide uppercase">Why Choose Us</span>
      </div>
      <h2 class="section-title text-white mb-6">
        Trusted Partner for Exhibition &<br class="hidden md:block" /> Display Construction
      </h2>
      <div class="max-w-2xl mx-auto space-y-3">
        {benefits.map((b) => (
          <div class="flex items-start gap-3 text-left">
            <svg class="w-5 h-5 text-brand-gold shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"/></svg>
            <p class="text-gray-300 text-sm leading-relaxed">{b}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {features.map((f, i) => (
        <div
          class="animate-on-scroll hover-lift group bg-brand-brown border border-white/10 hover:border-brand-gold/20 rounded-2xl p-6 text-center hover:shadow-xl hover:shadow-black/10"
          data-delay={String((i % 6) + 1)}
        >
          <div class="w-14 h-14 rounded-xl bg-brand-gold/10 flex items-center justify-center text-brand-gold mx-auto mb-5 transition-colors duration-300">
            <Fragment set:html={f.icon} />
          </div>
          <div class="mb-3">
            <span class="font-display text-3xl font-bold text-white">{f.value}</span>
            <span class="text-brand-gold font-display font-bold ml-1">{f.unit}</span>
          </div>
          <h3 class="font-display font-bold text-white mb-2">{f.title}</h3>
          <p class="text-gray-400 text-sm leading-relaxed">{f.description}</p>
        </div>
      ))}
    </div>

    <div class="text-center mt-12 animate-on-scroll">
      <a href="#contact" class="btn-primary">
        GET A QUOTE
        <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </div>
</section>
