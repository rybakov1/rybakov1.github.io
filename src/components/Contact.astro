---
interface Props {
  fullPage?: boolean;
}
const { fullPage = false } = Astro.props;
---

<section id="contact" class="section-padding bg-white">
  <div class="content-box">
    {!fullPage && (
      <div class="text-center mb-12 animate-on-scroll">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-brand-gold/10 mb-4">
          <span class="text-brand-gold text-xs font-semibold tracking-wide uppercase">Get In Touch</span>
        </div>
        <h2 class="section-title text-gray-900 mb-4">Contact Us</h2>
        <p class="section-subtitle text-gray-600">
          Ready to create an exhibition stand that makes an impact? Get in touch with us today.
        </p>
      </div>
    )}

    <div class="grid lg:grid-cols-2 gap-10 lg:gap-14">
      <!-- Form -->
      <div class="animate-on-scroll">
        <form class="space-y-5" id="contact-form">
          <div class="grid sm:grid-cols-2 gap-5">
            <input
              type="text"
              name="name"
              placeholder="Name"
              required
              class="w-full px-5 py-3.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-brand-gold/50 focus:border-brand-gold transition-all placeholder:text-gray-400 bg-gray-50 hover:bg-white"
            />
            <input
              type="email"
              name="email"
              placeholder="Email*"
              required
              class="w-full px-5 py-3.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-brand-gold/50 focus:border-brand-gold transition-all placeholder:text-gray-400 bg-gray-50 hover:bg-white"
            />
          </div>
          <input
            type="tel"
            name="phone"
            placeholder="Phone Number*"
            required
            class="w-full px-5 py-3.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-brand-gold/50 focus:border-brand-gold transition-all placeholder:text-gray-400 bg-gray-50 hover:bg-white"
          />
          <textarea
            name="message"
            placeholder="Tell us about your project..."
            rows="5"
            class="w-full px-5 py-3.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-brand-gold/50 focus:border-brand-gold transition-all placeholder:text-gray-400 resize-none bg-gray-50 hover:bg-white"
          ></textarea>
          <button type="submit" class="btn-primary w-full sm:w-auto !py-4 !px-10 text-base">
            Send Message
            <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5"/></svg>
          </button>
        </form>
      </div>

      <!-- Info & Map -->
      <div class="animate-on-scroll space-y-8">
        <!-- Contact cards -->
        <div class="grid sm:grid-cols-2 gap-4">
          <div class="bg-gray-50 rounded-xl p-5 border border-gray-100 hover:border-brand-gold/20 transition-colors">
            <div class="w-10 h-10 rounded-lg bg-brand-gold/10 flex items-center justify-center text-brand-gold mb-3">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            </div>
            <h4 class="font-semibold text-gray-900 text-sm mb-1">Phone</h4>
            <a href="tel:1800957469" class="text-brand-gold text-sm font-medium hover:underline">1800 957 469</a>
          </div>
          <div class="bg-gray-50 rounded-xl p-5 border border-gray-100 hover:border-brand-gold/20 transition-colors">
            <div class="w-10 h-10 rounded-lg bg-brand-gold/10 flex items-center justify-center text-brand-gold mb-3">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </div>
            <h4 class="font-semibold text-gray-900 text-sm mb-1">Email</h4>
            <a href="mailto:info@brijnco.com" class="text-brand-gold text-sm font-medium hover:underline">info@brijnco.com</a>
          </div>
          <div class="bg-gray-50 rounded-xl p-5 border border-gray-100 hover:border-brand-gold/20 transition-colors">
            <div class="w-10 h-10 rounded-lg bg-brand-gold/10 flex items-center justify-center text-brand-gold mb-3">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <h4 class="font-semibold text-gray-900 text-sm mb-1">Address</h4>
            <p class="text-gray-600 text-sm">4/8 Kerr Road Ingleburn NSW, 2565</p>
          </div>
          <div class="bg-gray-50 rounded-xl p-5 border border-gray-100 hover:border-brand-gold/20 transition-colors">
            <div class="w-10 h-10 rounded-lg bg-brand-gold/10 flex items-center justify-center text-brand-gold mb-3">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <h4 class="font-semibold text-gray-900 text-sm mb-1">Hours</h4>
            <p class="text-gray-600 text-sm">Mon-Fri: 8AM - 5PM</p>
          </div>
        </div>

        <!-- Map: 4/8 Kerr Road, Ingleburn NSW 2565 -->
        <div class="rounded-xl overflow-hidden border border-gray-200 aspect-video">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3312.0!2d150.857!3d-33.9986!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x6b12e913e4d7a9bf%3A0x5017d681632c840!2s8%20Kerr%20Rd%2C%20Ingleburn%20NSW%202565%2C%20Australia!5e0!3m2!1sen!2sau"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Brij & Co — 4/8 Kerr Road, Ingleburn NSW 2565"
          ></iframe>
        </div>
      </div>
    </div>
  </div>
</section>
