---
const capabilities = [
  { title: 'Woodworking', icon: '🪵' },
  { title: 'CNC Routing', icon: '⚙️' },
  { title: 'Vinyl Printing', icon: '🖨️' },
  { title: 'Electrical', icon: '⚡' },
  { title: 'Spray Painting', icon: '🎨' },
  { title: 'Metalwork', icon: '🔧' },
];

const expertiseCards = [
  {
    title: 'Expo Stand Builder',
    description: 'Our skilled project managers and builders are prepared to bring your vision to life.',
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17l-5.384-3.049A2 2 0 003 14.07V22h18V9.828a2 2 0 00-.863-1.646L16.5 5.5a2 2 0 00-2.313.041L11.42 7.7m0 7.47l3.557-2.29m-3.557 2.29V7.7m3.557 5.18L21 9.828"/></svg>`,
  },
  {
    title: 'Expo Stand Design',
    description: 'Creative design solutions to capture the right audience with maximum visual appeal.',
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42"/></svg>`,
  },
  {
    title: 'Custom Stands & Designs',
    description: 'A custom-built stand is always on brand. Be memorable. Be yourself. Be successful at any event.',
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 7.5l-2.25-1.313M21 7.5v2.25m0-2.25l-2.25 1.313M3 7.5l2.25-1.313M3 7.5l2.25 1.313M3 7.5v2.25m9 3l2.25-1.313M12 12.75l-2.25-1.313M12 12.75V15m0 6.75l2.25-1.313M12 21.75V19.5m0 2.25l-2.25-1.313m0-16.875L12 2.25l2.25 1.313M21 14.25v2.25l-2.25 1.313m-13.5 0L3 16.5v-2.25"/></svg>`,
  },
  {
    title: 'Turnkey Booths',
    description: 'Turnkey and tool-free — portable stands designed for easy transport and assembly.',
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 013 3m3 0a6 6 0 01-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1121.75 8.25z"/></svg>`,
  },
];
---

<section class="section-padding bg-gray-50">
  <div class="content-box">
    <!-- Your Success is Handmade -->
    <div class="text-center mb-12 animate-on-scroll">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-brand-gold/10 mb-4">
        <span class="text-brand-gold text-xs font-semibold tracking-wide uppercase">Our Craft</span>
      </div>
      <h2 class="section-title text-gray-900 mb-4">Your Success Is Handmade</h2>
      <p class="section-subtitle text-gray-600">
        We have our own production facilities, and all work is carried out by our skilled tradesmen. You can be confident everything will be completed on time and to the highest possible standard.
      </p>
    </div>

    <!-- Manufacturing capabilities -->
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 mb-20">
      {capabilities.map((cap, i) => (
        <div
          class="animate-on-scroll hover-lift group bg-white rounded-xl p-6 text-center border border-gray-200 hover:border-brand-gold/20 hover:shadow-lg"
          data-delay={String((i % 6) + 1)}
        >
          <span class="text-3xl block mb-3">{cap.icon}</span>
          <h4 class="font-display font-semibold text-gray-900 text-sm uppercase tracking-wider">{cap.title}</h4>
        </div>
      ))}
    </div>

    <!-- Expertise cards -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {expertiseCards.map((card, i) => (
        <div
          class="animate-on-scroll hover-lift group bg-white rounded-2xl p-6 border border-gray-100 hover:border-brand-gold/20 hover:shadow-xl text-center"
          data-delay={String((i % 6) + 1)}
        >
          <div class="w-14 h-14 rounded-xl bg-brand-gold/10 flex items-center justify-center text-brand-gold mx-auto mb-5 transition-colors">
            <Fragment set:html={card.icon} />
          </div>
          <h3 class="font-display font-bold text-gray-900 mb-2">{card.title}</h3>
          <p class="text-gray-500 text-sm leading-relaxed">{card.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
