---

---

<section class="section-padding bg-white">
  <div class="content-box">
    <div class="grid lg:grid-cols-2 gap-10 lg:gap-14 items-center">
      <!-- Image -->
      <div class="animate-on-scroll order-2 lg:order-1">
        <div class="relative">
          <div class="aspect-[4/3] rounded-2xl overflow-hidden bg-brand-dark">
            <img
              src="/good_images_pack/CES2-1.jpg"
              alt="One stop shop — exhibition design to build under one roof"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
          <div class="absolute -bottom-4 -left-4 w-32 h-32 bg-brand-gold/10 rounded-2xl -z-10"></div>
        </div>
      </div>

      <!-- Content -->
      <div class="animate-on-scroll order-1 lg:order-2">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-brand-gold/10 mb-6">
          <span class="text-brand-gold text-xs font-semibold tracking-wide uppercase">All Under One Roof</span>
        </div>

        <h2 class="section-title text-gray-900 mb-6">
          One Stop Shop — From Design to Build
        </h2>

        <div class="space-y-4 text-gray-600 leading-relaxed">
          <p>
            We are a <strong class="text-gray-900">one-stop company</strong> that provides you with everything under one roof — exhibition display stands from design to build. Imagine working with us as a single team to help you achieve everything from designing to construction on a single platform.
          </p>
          <p>
            Our integrated construction & design approach focuses on a cost-effective and faster development process to help you acquire the best show stands. No need to juggle multiple teams.
          </p>
        </div>

        <!-- Process Steps -->
        <div class="mt-8 space-y-4">
          <div class="flex items-center gap-4 p-4 bg-gray-50 rounded-xl border border-gray-100 hover:border-brand-gold/20 transition-colors">
            <div class="w-10 h-10 rounded-full bg-brand-gold flex items-center justify-center text-white font-display font-bold text-sm shrink-0">1</div>
            <div>
              <h4 class="font-semibold text-gray-900 text-sm">Design & Concept</h4>
              <p class="text-xs text-gray-500">Expert designers visualize your ideas into real projects</p>
            </div>
          </div>
          <div class="flex items-center gap-4 p-4 bg-gray-50 rounded-xl border border-gray-100 hover:border-brand-gold/20 transition-colors">
            <div class="w-10 h-10 rounded-full bg-brand-gold flex items-center justify-center text-white font-display font-bold text-sm shrink-0">2</div>
            <div>
              <h4 class="font-semibold text-gray-900 text-sm">Manufacturing</h4>
              <p class="text-xs text-gray-500">Our factory brings designs to reality with precision</p>
            </div>
          </div>
          <div class="flex items-center gap-4 p-4 bg-gray-50 rounded-xl border border-gray-100 hover:border-brand-gold/20 transition-colors">
            <div class="w-10 h-10 rounded-full bg-brand-gold flex items-center justify-center text-white font-display font-bold text-sm shrink-0">3</div>
            <div>
              <h4 class="font-semibold text-gray-900 text-sm">Install & Dismantle</h4>
              <p class="text-xs text-gray-500">Full setup at venue and dismantling included</p>
            </div>
          </div>
        </div>

        <a href="#contact" class="btn-primary mt-8 inline-flex">
          Learn More
          <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>
