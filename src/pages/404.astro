---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Page not found — Brij & Co" description="The page you are looking for could not be found.">
  <main id="main" class="min-h-[60vh] flex items-center justify-center content-box section-padding">
    <div class="text-center">
      <p class="text-6xl font-display font-bold text-brand-gold mb-4">404</p>
      <h1 class="text-2xl font-display font-bold text-gray-900 mb-2">Page not found</h1>
      <p class="text-gray-500 mb-8 max-w-md mx-auto">The page you're looking for doesn't exist or has been moved.</p>
      <a href="/" class="btn-primary">Back to home</a>
    </div>
  </main>
</Layout>
