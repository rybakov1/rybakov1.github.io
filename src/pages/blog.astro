---
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import { posts, formatDate } from '../data/blog';
---

<Layout
  title="Blog — Brij & Co | Exhibition Stand Design & Build"
  description="Articles and tips on exhibition stand design, trade show stands, and working with exhibition builders in Sydney and Australia."
  canonical="https://rybakov1.github.io/blog"
>
  <Header />
  <main id="main">
    <!-- Page title & breadcrumb -->
    <section class="bg-brand-cream border-b border-gray-200">
      <div class="content-box py-10 md:py-12">
        <nav class="text-sm text-gray-500 mb-2" aria-label="Breadcrumb">
          <a href="/" class="hover:text-brand-gold transition-colors">Home</a>
          <span class="mx-2">»</span>
          <span class="text-gray-700 font-medium">Blog</span>
        </nav>
        <h1 class="text-3xl md:text-4xl font-display font-bold text-gray-900">Blog</h1>
      </div>
    </section>

    <section class="section-padding bg-white">
      <div class="content-box">
        <div class="grid lg:grid-cols-3 gap-10 lg:gap-14">
          <!-- Post list -->
          <div class="lg:col-span-2 space-y-10">
            {posts.map((post) => (
              <article class="animate-on-scroll group border-b border-gray-100 pb-10 last:border-0 last:pb-0">
                <a href={`/blog/${post.slug}`} class="block">
                  <div class="aspect-video rounded-xl overflow-hidden bg-brand-dark mb-5">
                    <img
                      src={post.image}
                      alt=""
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                      loading="lazy"
                    />
                  </div>
                  <h2 class="font-display text-xl md:text-2xl font-bold text-gray-900 mb-2 group-hover:text-brand-gold transition-colors">
                    {post.title}
                  </h2>
                  <time class="text-sm text-gray-500 block mb-3" datetime={post.date}>
                    {formatDate(post.date)}
                  </time>
                  <p class="text-gray-600 text-sm leading-relaxed mb-4">
                    {post.excerpt}
                  </p>
                  <span class="text-brand-gold text-sm font-semibold inline-flex items-center gap-1 hover:gap-2 transition-all">
                    Read more
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                    </svg>
                  </span>
                </a>
              </article>
            ))}
          </div>

          <!-- Sidebar: Recent Posts -->
          <aside class="lg:col-span-1">
            <div class="lg:sticky lg:top-28">
              <h3 class="font-display font-bold text-gray-900 text-lg mb-6">Recent Posts</h3>
              <ul class="space-y-5">
                {posts.map((post) => (
                  <li>
                    <a href={`/blog/${post.slug}`} class="flex gap-4 group">
                      <div class="w-20 h-16 rounded-lg overflow-hidden bg-brand-dark shrink-0">
                        <img
                          src={post.image}
                          alt=""
                          class="w-full h-full object-cover group-hover:scale-105 transition-transform"
                          loading="lazy"
                        />
                      </div>
                      <div class="min-w-0">
                        <span class="font-medium text-gray-900 text-sm line-clamp-2 group-hover:text-brand-gold transition-colors block">
                          {post.title}
                        </span>
                        <time class="text-xs text-gray-500 mt-1 block" datetime={post.date}>
                          {formatDate(post.date)}
                        </time>
                      </div>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </aside>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
