---
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import Hero from '@components/Hero.astro';
import About from '@components/About.astro';
import Services from '@components/Services.astro';
import Solutions360 from '@components/Solutions360.astro';
import OneStopShop from '@components/OneStopShop.astro';
import WhyChooseUs from '@components/WhyChooseUs.astro';
import Projects from '@components/Projects.astro';
import Craftsmanship from '@components/Craftsmanship.astro';
import AcrossAustralia from '@components/AcrossAustralia.astro';
import Testimonials from '@components/Testimonials.astro';
import Contact from '@components/Contact.astro';
import Footer from '@components/Footer.astro';
---

<Layout title="Brij & Co — Custom Exhibition Stand Builders Sydney & NSW">
  <Header />
  <main id="main">
    <Hero />
    <About />
    <Services />
    <Solutions360 />
    <OneStopShop />
    <WhyChooseUs />
    <Projects />
    <Craftsmanship />
    <AcrossAustralia />
    <Testimonials />
    <Contact />
  </main>
  <Footer />
</Layout>
